# FastAPI AI worker — copy to .env or set in shell.

AI_INTERNAL_KEY=dev-internal
AI_PROVIDER=ollama
AI_EMBED_PROVIDER=ollama
AI_CHAT_MODEL=local-default
AI_EMBED_MODEL=local-default
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=llama3.2-vision:11b-instruct-q4_K_M
OLLAMA_CHAT_FALLBACK_MODELS=llama3.2:3b-instruct-q4_K_M,mistral:7b-instruct-q4_K_M
OLLAMA_NUM_CTX=8192
OLLAMA_NUM_PREDICT=768
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40
OLLAMA_REPEAT_PENALTY=1.12
OLLAMA_TEMPERATURE_MIN=0.2
OLLAMA_TEMPERATURE_MAX=1.5
AI_RESPONSE_STYLE=balanced
AI_ENABLE_PROMPT_BOOST=true
AI_TIMEOUT_SECONDS=90

# Optional: LM Studio / vLLM / any OpenAI-compatible local server (NOT cloud OpenAI).
# Example LM Studio: LOCAL_LLM_COMPAT_BASE_URL=http://127.0.0.1:1234/v1
# LOCAL_LLM_COMPAT_API_KEY=
# LOCAL_LLM_COMPAT_CHAT_MODEL=your-loaded-model-name
# LOCAL_LLM_COMPAT_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# Optional: host binding when using uvicorn directly
# HOST=0.0.0.0
# PORT=8001
