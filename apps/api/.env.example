# Match infra/docker-compose.yml (Postgres :5433, Redis :6380). Use 127.0.0.1 if localhost fails on Windows.
DATABASE_URL=postgresql://persona:persona_dev@127.0.0.1:5433/persona
# Optional — leave empty if Docker Redis is not running (API works without Redis until you use it).
REDIS_URL=redis://127.0.0.1:6380

API_PORT=3001

JWT_SECRET=change-me-in-production

AI_SERVICE_URL=http://127.0.0.1:8001
AI_INTERNAL_KEY=dev-internal
AI_DEFAULT_PROVIDER=local
AI_CHAT_TIMEOUT_MS=120000
AI_EMBED_TIMEOUT_MS=30000
MEDIA_SERVICE_URL=http://127.0.0.1:8003
MEDIA_SERVICE_TIMEOUT_MS=120000
MEDIA_UPLOAD_MAX_BYTES=26214400

# Voice synthesis provider: mock | openai
VOICE_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Post-chat memory: async semantic rows + model JSON extraction (uses same local AI worker).
# Set to false to skip extra embed/complete calls (e.g. load tests).
MEMORY_DEFERRED_EXTRACTION=true
# Optional: override chat model name for extraction only (worker must support it).
# MEMORY_EXTRACTION_MODEL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3002/account?sub=ok
STRIPE_CANCEL_URL=http://localhost:3002/pricing

CCBILL_ACCOUNT_NUMBER=
CCBILL_SUBACCOUNT_NUMBER=
CCBILL_API_KEY=
CCBILL_WEBHOOK_SECRET=
CCBILL_SUCCESS_URL=http://localhost:3002/account?sub=ok
CCBILL_CANCEL_URL=http://localhost:3002/pricing

CRYPTO_GATEWAY_API_KEY=
CRYPTO_GATEWAY_WEBHOOK_SECRET=
CRYPTO_SUCCESS_URL=http://localhost:3002/account?sub=ok
CRYPTO_CANCEL_URL=http://localhost:3002/pricing

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
