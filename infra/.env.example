# Copy to repo-root `.env` (recommended) or `infra/.env`.
# Compose loads `.env` from your current working directory when you run docker compose.

POSTGRES_USER=persona
POSTGRES_PASSWORD=persona_dev
POSTGRES_DB=persona

# App connection strings (match ports in docker-compose.yml). Prefer 127.0.0.1 on Windows if localhost misbehaves.
DATABASE_URL=postgresql://persona:persona_dev@127.0.0.1:5433/persona
REDIS_URL=redis://127.0.0.1:6380

# If Docker Hub fails (TLS timeout / HTTPS errors), use a mirror or pre-loaded image name:
# PERSONA_REDIS_IMAGE=redis:7.4-alpine
#
# Offline workaround: on a PC with working pulls:
#   docker pull redis:7.4-alpine
#   docker save redis:7.4-alpine -o redis-74.tar
# Copy the .tar here, then: docker load -i redis-74.tar
# Re-run compose (default image name matches what you loaded).
