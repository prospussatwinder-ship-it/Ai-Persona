generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  CUSTOMER
}

enum MessageRole {
  user
  assistant
  system
}

enum MemorySource {
  chat_summary
  user_fact
  explicit_note
  import
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  trialing
  incomplete
}

enum PurchaseStatus {
  pending
  succeeded
  failed
}

enum ScheduledPostStatus {
  PENDING
  PUBLISHED
  FAILED
  CANCELLED
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  role             UserRole @default(CUSTOMER)
  displayName      String?
  stripeCustomerId String?  @unique
  ageVerified      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  personasAuthored Persona[]      @relation("PersonaAuthor")
  conversations    Conversation[]
  memoryEntries    MemoryEntry[]
  subscriptions    Subscription[]
  purchases        Purchase[]
  entitlements     Entitlement[]
  analyticsEvents  AnalyticsEvent[]
  auditLogs        AuditLog[]     @relation("AuditActor")
}

model Persona {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  isPublished Boolean  @default(false)
  createdById String?
  createdBy   User?    @relation("PersonaAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile         PersonaProfile?
  conversations   Conversation[]
  memoryEntries   MemoryEntry[]
  scheduledPosts  ScheduledPost[]
  analyticsEvents AnalyticsEvent[]
}

model PersonaProfile {
  id            String   @id @default(cuid())
  personaId     String   @unique
  persona       Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  tagline       String?
  description   String?  @db.Text
  avatarUrl     String?
  systemPrompt  String?  @db.Text
  agentConfig   Json?
  voiceConfig   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaId String
  persona   Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([userId, personaId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String        @db.Text
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([conversationId, createdAt])
}

model MemoryEntry {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaId      String
  persona        Persona      @relation(fields: [personaId], references: [id], onDelete: Cascade)
  conversationId String?
  source         MemorySource
  content        String       @db.Text
  metadata       Json?
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime     @default(now())

  @@index([userId, personaId])
}

model Subscription {
  id                   String               @id @default(cuid())
  userId               String
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String               @unique
  stripePriceId        String?
  status               SubscriptionStatus
  currentPeriodEnd     DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([userId])
}

model Purchase {
  id                    String         @id @default(cuid())
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String?        @unique
  amountCents           Int
  currency              String         @default("usd")
  productKey            String
  status                PurchaseStatus
  fulfilledAt           DateTime?
  createdAt             DateTime       @default(now())

  @@index([userId])
}

model Entitlement {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceType String
  resourceId   String?
  validFrom    DateTime  @default(now())
  validUntil   DateTime?
  source       String

  @@index([userId, resourceType])
}

model ScheduledPost {
  id           String               @id @default(cuid())
  personaId    String
  persona      Persona              @relation(fields: [personaId], references: [id], onDelete: Cascade)
  body         String               @db.Text
  mediaUrl     String?
  scheduledFor DateTime
  status       ScheduledPostStatus  @default(PENDING)
  publishedAt  DateTime?
  metadata     Json?
  createdAt    DateTime             @default(now())

  @@index([personaId, scheduledFor])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  personaId String?
  persona   Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}
