generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OPERATOR
  CUSTOMER
}

enum UserAccountStatus {
  active
  inactive
  suspended
}

enum BillingCycle {
  MONTHLY
  YEARLY
  LIFETIME
  ONCE
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum AccountSubscriptionStatus {
  active
  inactive
  expired
  cancelled
  pending
  trial
}

enum MessageRole {
  user
  assistant
  system
}

enum PersonaVisibility {
  PUBLIC
  PRIVATE
}

enum MemorySource {
  chat_summary
  user_fact
  explicit_note
  import
}

enum PersonaAccessType {
  purchased
  assigned
  subscription
  admin_granted
}

enum UserPersonaAccessStatus {
  active
  inactive
  revoked
}

enum UserPersonaTrainingStatus {
  active
  archived
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  trialing
  incomplete
}

enum PurchaseStatus {
  pending
  succeeded
  failed
}

enum ScheduledPostStatus {
  PENDING
  PUBLISHED
  FAILED
  CANCELLED
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  role             UserRole @default(CUSTOMER)
  displayName      String?
  firstName        String?
  lastName         String?
  phone            String?
  avatarUrl        String?
  status           UserAccountStatus @default(active)
  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  deletedAt        DateTime?
  createdById      String?
  updatedById      String?
  stripeCustomerId String?  @unique
  ageVerified      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy        User?    @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?    @relation("UserUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdUsers     User[]   @relation("UserCreatedBy")
  updatedUsers     User[]   @relation("UserUpdatedBy")

  personasAuthored Persona[]      @relation("PersonaAuthor")
  conversations    Conversation[]
  memoryEntries    MemoryEntry[]
  subscriptions    Subscription[]
  purchases        Purchase[]
  entitlements     Entitlement[]
  analyticsEvents  AnalyticsEvent[]
  auditLogs        AuditLog[]     @relation("AuditActor")
  passwordResetTokens PasswordResetToken[]
  userPlanSubscriptions UserPlanSubscription[]
  aiUsageLogs      AiUsageLog[]
  billingTransactions BillingTransaction[]
  personaAccesses   UserPersonaAccess[]
  personaTrainings  UserPersonaTrainingProfile[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Role {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  slug        String   @unique
  module      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model SubscriptionPlan {
  id               String      @id @default(cuid())
  name             String
  slug             String      @unique
  description      String?
  price            Decimal     @default(0) @db.Decimal(12, 2)
  currency         String      @default("usd")
  billingCycle     BillingCycle
  trialDays        Int         @default(0)
  aiRequestLimit   Int         @default(0)
  maxUsers         Int?
  maxProjects      Int?
  maxFiles         Int?
  featureConfig    Json?
  status           PlanStatus  @default(ACTIVE)
  sortOrder        Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  userSubscriptions UserPlanSubscription[]
}

model UserPlanSubscription {
  id                  String                   @id @default(cuid())
  userId              String
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId              String
  plan                SubscriptionPlan         @relation(fields: [planId], references: [id], onDelete: Restrict)
  status              AccountSubscriptionStatus
  startDate           DateTime?
  endDate             DateTime?
  renewalDate         DateTime?
  cancelAtPeriodEnd   Boolean                  @default(false)
  trialStartDate      DateTime?
  trialEndDate        DateTime?
  metadata            Json?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  aiUsageLogs AiUsageLog[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@map("user_subscriptions")
}

model AiUsageLog {
  id               String               @id @default(cuid())
  userId           String
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId   String?
  subscription     UserPlanSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  featureName      String
  requestType      String
  creditsUsed      Int                  @default(1)
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  status           String               @default("ok")
  createdAt        DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([subscriptionId])
}

model BillingTransaction {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider    String   @default("stripe")
  externalId  String?
  amountCents Int      @default(0)
  currency    String   @default("usd")
  status      String   @default("pending")
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([externalId])
}

model Persona {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  isPublished Boolean  @default(false)
  isActive    Boolean  @default(true)
  visibility  PersonaVisibility @default(PUBLIC)
  createdById String?
  createdBy   User?    @relation("PersonaAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile         PersonaProfile?
  conversations   Conversation[]
  memoryEntries   MemoryEntry[]
  scheduledPosts  ScheduledPost[]
  analyticsEvents AnalyticsEvent[]
  accessGrants    UserPersonaAccess[]
  trainingProfiles UserPersonaTrainingProfile[]
}

model PersonaProfile {
  id            String   @id @default(cuid())
  personaId     String   @unique
  persona       Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  tagline       String?
  description   String?  @db.Text
  avatarUrl     String?
  systemPrompt  String?  @db.Text
  scopeName     String?
  scopeDescription String? @db.Text
  allowedTopics Json?
  blockedTopics Json?
  behaviorRules String? @db.Text
  feedData      Json?
  agentConfig   Json?
  voiceConfig   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaId String
  persona   Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([userId, personaId])
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String        @db.Text
  metadata       Json?
  createdAt      DateTime      @default(now())

  @@index([conversationId, createdAt])
}

model MemoryEntry {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaId      String
  persona        Persona      @relation(fields: [personaId], references: [id], onDelete: Cascade)
  conversationId String?
  source         MemorySource
  memoryKey      String?
  memoryType     String?
  confidenceScore Float?
  content        String       @db.Text
  metadata       Json?
  embedding      Unsupported("vector(1536)")?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId, personaId])
  @@index([userId, personaId, memoryKey])
}

model UserPersonaAccess {
  id         String                 @id @default(cuid())
  userId     String
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaId  String
  persona    Persona                @relation(fields: [personaId], references: [id], onDelete: Cascade)
  accessType PersonaAccessType
  status     UserPersonaAccessStatus @default(active)
  startDate  DateTime?
  endDate    DateTime?
  metadata   Json?
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([userId, personaId, accessType])
  @@index([userId, status])
  @@index([personaId, status])
}

model UserPersonaTrainingProfile {
  id                String                   @id @default(cuid())
  userId            String
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  personaId         String
  persona           Persona                  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  title             String?
  trainingNotes     String?                  @db.Text
  structuredProfile Json?
  status            UserPersonaTrainingStatus @default(active)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@unique([userId, personaId])
  @@index([userId, status])
  @@index([personaId, status])
}

model Subscription {
  id                   String               @id @default(cuid())
  userId               String
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String               @unique
  stripePriceId        String?
  status               SubscriptionStatus
  currentPeriodEnd     DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([userId])
}

model Purchase {
  id                    String         @id @default(cuid())
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String?        @unique
  amountCents           Int
  currency              String         @default("usd")
  productKey            String
  status                PurchaseStatus
  fulfilledAt           DateTime?
  createdAt             DateTime       @default(now())

  @@index([userId])
}

model Entitlement {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceType String
  resourceId   String?
  validFrom    DateTime  @default(now())
  validUntil   DateTime?
  source       String

  @@index([userId, resourceType])
}

model ScheduledPost {
  id           String               @id @default(cuid())
  personaId    String
  persona      Persona              @relation(fields: [personaId], references: [id], onDelete: Cascade)
  body         String               @db.Text
  mediaUrl     String?
  scheduledFor DateTime
  status       ScheduledPostStatus  @default(PENDING)
  publishedAt  DateTime?
  metadata     Json?
  createdAt    DateTime             @default(now())

  @@index([personaId, scheduledFor])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  personaId String?
  persona   Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  ip          String?
  module      String?
  description String?
  oldValues   Json?
  newValues   Json?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([module, createdAt])
  @@index([createdAt])
}
